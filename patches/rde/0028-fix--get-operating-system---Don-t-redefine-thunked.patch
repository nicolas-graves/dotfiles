From 8cb933c7271f57dc6547dd7cc9c95b7c6bb3cc82 Mon Sep 17 00:00:00 2001
From: Nicolas Graves <ngraves@ngraves.fr>
Date: Thu, 26 Mar 2026 08:27:02 +0100
Subject: [PATCH 28/28] fix!(get-operating-system): Don't redefine thunked fields

This is a follow-up to a7c8e68dc51144a6d3981b770aca9c4897fc7c0c, which
redefines thunked fields and overwrites the previous values of thunked
fields (here: initrd-modules and services).

* src/rde/features.scm (get-operating-system): Fix thunked fields
redefinition.

---
diff --git a/src/rde/features.scm b/src/rde/features.scm
index 08cb67d..ba7e8d6 100644
--- a/src/rde/features.scm
+++ b/src/rde/features.scm
@@ -370,8 +370,6 @@ can be later used to extend original service with additional configuration."
                                 (supplementary-groups user-groups))
                                #f))
 
-         (services         (rde-config-system-services config))
-
          (kernel           (get-value
                             'kernel config
                             (operating-system-kernel initial-os)))
@@ -384,9 +382,6 @@ can be later used to extend original service with additional configuration."
          (initrd           (get-value
                             'initrd config
                             (operating-system-initrd initial-os)))
-         (initrd-modules   (get-value
-                            'initrd-modules config
-                            (operating-system-initrd-modules initial-os)))
          (firmware         (get-value
                             'firmware config
                             (operating-system-firmware initial-os)))
@@ -411,10 +406,10 @@ can be later used to extend original service with additional configuration."
             (kernel-arguments kernel-arguments)
             (kernel-loadable-modules kernel-modules)
             (initrd initrd)
-            (initrd-modules initrd-modules)
+            (initrd-modules (get-value 'initrd-modules config initrd-modules))
             (firmware firmware)
             (services (append
-                       services
+                       (rde-config-system-services config)
                        (if (rde-config-integrate-he-in-os? config)
                            (list (service guix-home-service-type
                                           ;; TODO: [Andrew Tropin, 2024-05-27]

--
